{
  "manifest_version": 3,
  "name": "Starlink Help Tree",
  "version": "1.0",
  "description": "Starlink Help Center for Support Agents",
  "permissions": ["sidePanel", "activeTab", "scripting"],

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_icon": "icon.png",
    "default_title": "Starlink Help Tree"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "background": {
    "service_worker": "background.js"
  }
}