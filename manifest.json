{
  "manifest_version": 3,
  "name": "Starlink Help Tree",
  "version": "1.0",
  "description": "Starlink Help Center - Quick answers in side panel",
  "permissions": ["sidePanel"],
  "action": {
    "default_icon": "icon.jpg",
    "default_title": "Open Starlink Help Tree"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}